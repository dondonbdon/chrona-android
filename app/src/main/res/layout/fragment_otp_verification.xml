        <TextView
            android:id="@+id/verificationResendText"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="20dp"
            android:background="@drawable/rect_20dp"
            android:backgroundTint="@color/grey15"
            android:fontFamily="@font/fo_outfit_regular"
            android:paddingHorizontal="20dp"
            android:paddingVertical="10dp"
            android:text="@string/resend"
            android:textColor="@color/grey"
            android:visibility="gone"
            android:textSize="16sp"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toBottomOf="@+id/constraintLayout" />

        <androidx.appcompat.widget.AppCompatButton
            android:id="@+id/verificationBtn"
            android:layout_width="match_parent"
            android:layout_height="60dp"
            android:layout_marginHorizontal="16dp"
            android:layout_marginTop="20dp"
            android:layout_marginBottom="10dp"
            android:background="@drawable/rect_20dp"
            android:backgroundTint="@color/m1"
            android:fontFamily="@font/fo_outfit_regular"
            android:outlineProvider="none"
            android:text="@string/send_code"
            android:textAllCaps="false"
            android:textColor="@color/white"
            android:textSize="16sp"
            app:layout_constraintBottom_toTopOf="@+id/verificationOptBtn"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toBottomOf="@+id/verificationResendText" />

        <androidx.appcompat.widget.AppCompatButton
